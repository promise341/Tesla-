generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String           @id @default(uuid())
  username          String           @unique
  name              String
  email             String           @unique
  phone             String
  country           String
  passwordHash      String
  balance           Float            @default(0.0)
  totalProfit       Float            @default(0.0)
  totalWithdraw     Float            @default(0.0)
  avatar            String?
  kycStatus         String           @default("UNVERIFIED")
  kycDocFront       String?
  kycDocBack        String?
  kycSelfie         String?
  kycSubmittedAt    DateTime?
  role              String           @default("USER")
  createdAt         DateTime         @default(now())
  activePlans       ActivePlan[]
  depositAddresses  DepositAddress[]
  giveawayEntries   GiveawayEntry[]
  notifications     Notification[]
  orders            Order[]
  referralsReceived Referral[]       @relation("RefereeRelation")
  referralsSent     Referral[]       @relation("ReferrerRelation")
  trades            Trade[]
  transactions      Transaction[]
  vipMemberships    VipMembership[]
}

model Transaction {
  id                String   @id @default(uuid())
  userId            String
  type              String
  amount            Float
  method            String
  address           String?
  status            String
  proofImageUrl     String?
  proofStatus       String?  @default("PENDING")
  userWalletAddress String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])
}

model ActivePlan {
  id                String   @id @default(uuid())
  userId            String
  planName          String
  capital           Float
  rate              Float
  status            String
  paymentMethod     String?
  paymentStatus     String?
  paymentProofUrl   String?
  userWalletAddress String?
  category          String?
  createdAt         DateTime @default(now())
  lastPayout        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])
}

model Car {
  id          String  @id @default(uuid())
  name        String
  rangeMiles  String
  topSpeed    String
  zeroToSixty String?
  price       Float
  imageUrl    String
  isFeatured  Boolean @default(false)
}

model Order {
  id            String   @id @default(uuid())
  userId        String
  carId         String
  carName       String
  price         Float
  fullName      String
  email         String
  phone         String   @default("")
  company       String   @default("")
  street        String
  city          String
  state         String   @default("")
  postalCode    String   @default("")
  country       String
  paymentMethod String
  walletAddress String
  proofUrl      String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model VipMembership {
  id            String    @id @default(uuid())
  userId        String
  cardName      String
  price         Float
  duration      String
  paymentMethod String    @default("")
  proofUrl      String    @default("")
  status        String    @default("PENDING")
  payStatus     String    @default("PAYMENT_PENDING")
  createdAt     DateTime  @default(now())
  expiresAt     DateTime?
  user          User      @relation(fields: [userId], references: [id])
}

model Giveaway {
  id          String          @id @default(uuid())
  title       String
  description String
  prize       String
  prizeType   String          @default("CASH")
  imageUrl    String          @default("")
  status      String          @default("ACTIVE")
  endsAt      DateTime
  maxEntries  Int             @default(0)
  createdAt   DateTime        @default(now())
  entries     GiveawayEntry[]
}

model GiveawayEntry {
  id         String   @id @default(uuid())
  userId     String
  giveawayId String
  status     String   @default("ENTERED")
  createdAt  DateTime @default(now())
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, giveawayId])
}

model Trade {
  id           String    @id @default(uuid())
  userId       String
  instrumentId String
  pair         String
  name         String
  category     String
  side         String
  orderType    String    @default("MARKET")
  leverage     Int       @default(1)
  expiration   String    @default("GTC")
  entryPrice   Float
  amount       Float
  units        Float
  stopLoss     Float?
  takeProfit   Float?
  status       String    @default("OPEN")
  closePrice   Float?
  pnl          Float?
  pnlPct       Float?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  user         User      @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model DepositAddress {
  id        String   @id @default(uuid())
  userId    String
  currency  String
  address   String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id          String    @id @default(uuid())
  referrerId  String
  refereeId   String
  bonusAmount Float     @default(0.0)
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  creditedAt  DateTime?
  referee     User      @relation("RefereeRelation", fields: [refereeId], references: [id], onDelete: Cascade)
  referrer    User      @relation("ReferrerRelation", fields: [referrerId], references: [id], onDelete: Cascade)

  @@unique([referrerId, refereeId])
}
